	PokemonProfessor: {
		DisplayName: Profesor Pokemon
		Census.SpawnCondition: Disponible inmediatamente

		TownNPCMood: {
			Content: Los Pokemon salvajes parecen tranquilos aquí.
			NoHome: Investigar sin laboratorio será un reto, pero me las arreglaré.
			FarFromHome: Es toda una aventura andar por aquí.
			LoveSpace: ¡Hay espacio suficiente para hacer todo tipo de experimentos!
			DislikeCrowded: Los Pokemon se asustan con demasiada gente alrededor.
			HateCrowded: Este lugar está tan concurrido que los Pokemon se inquietan.
			LoveBiome: La suave brisa de {BiomeName} lo convierte en el lugar perfecto para mi investigación.
			LikeBiome: "{BiomeName} es un lugar muy agradable."
			DislikeBiome: "{BiomeName} tiene un ambiente un tanto inquietante. No me convence."
			HateBiome: Hace demasiado frío aquí en {BiomeName}. is pobres Pokemon se congelarán.
			LoveNPC: ¡{NPCName} realmente entiende la importancia de documentar a estas fascinantes criaturas!
			LikeNPC: "{NPCName} me recuerda a alguien que conocí en mi ciudad. Es muy servicial."
			DislikeNPC: No confío en {NPCName}. No me cae muy bien.
			HateNPC: No puedo creer que {NPCName} se gane la vida vendiendo armas. ¿No podría hacer algo no tan peligroso?
			LikeNPC_Princess: "{NPCName} es un encanto."
			Princess_LovesNPC: "{NPCName} abe muchísimo, ¡y sus Pokemon son tan tiernos!"
		}
	}

	FishermanTrainer.DisplayName: Pescador Entrenador

	PokemonScientist: {
		DisplayName: Científico
		Census.SpawnCondition: Tener una muestra genética en tu inventario

		TownNPCMood: {
			Content: Aún tengo mis lentes, así que todo está bien.
			NoHome: En serio necesito un nuevo laboratorio. La ciencia no espera a nadie.
			FarFromHome: Me parece que estoy perdido.
			LoveSpace: ¡Aquí hay suficiente espacio para hacer todo tipo de experimentos!
			DislikeCrowded: Hay algo de ruido por aquí. Preferiría un lugar más tranquilo.
			HateCrowded: ¡Con toda esta gente ni siquiera puedo escuchar mis pensamientos!
			LoveBiome: Me encanta el {BiomeName}, es perfecto para una tranquila sesión de investigación.
			LikeBiome: El {BiomeName} tiene muchas cosas interesantes escondidas bajo la arena.
			DislikeBiome: No me fascina el {BiomeName}, es muy... vivo.
			HateBiome: No puedo concentrarme en mi trabajo con todos estos monstruos de la {BiomeName}.
			LoveNPC: ¡Realmente admiro el genio de {NPCName}!
			LikeNPC: Puedo respetar que {NPCName} también tenga algo de científica.
			DislikeNPC: "{NPCName} debe guardarse sus hojas para ella misma."
			HateNPC: "{NPCName} no tiene ningún respeto por la precisión y el delicado equilibrio que requiere la verdadera ciencia."
			LikeNPC_Princess: "{NPCName} de verdad me escucha cuando hablo de rocas. Casi me da pena."
			Princess_LovesNPC: ¡{NPCName} sabe tantas cosas interesantes!
		}
	}

	MoveTutor: {
		// DisplayName: Move Tutor
		// Census.SpawnCondition: Have a Pokemon forget a move.

		TownNPCMood: {
			// Content: I feel ready to wrestle a Machoke.
			// NoHome: I can't train without a home to rest in.
			// FarFromHome: I'm not lost. I'm just... exploring.
			// LoveSpace: I've got enough space to practice my kicks without breaking anything!
			// DislikeCrowded: I'm not so sure I can train with so many people nearby. I'd hate to accidently hit someone.
			// HateCrowded: I can't even meditate with so many people nearby!
			// LoveBiome: I love training beside the sounds of {BiomeName}.
			// LikeBiome: I like that {BiomeName} offers forgiving ground for practicing throws.
			// DislikeBiome: I can't handle the cold of {BiomeName}.
			// HateBiome: I hate {BiomeName}. I get too claustrophobic.
			// LoveNPC: I love the way {NPCName} talks about Pokemon. They get so fired up!
			// LikeNPC: The muscles on {NPCName} really set a high bar. I need to keep training so I can keep up!
			// DislikeNPC: "{NPCName} should take their weird gizmos somewhere else."
			// HateNPC: I don't think {NPCName} has ever worked a day in their life. It makes me sick.
			// LikeNPC_Princess: "{NPCName} is so lovely, and has surprisingly quick reflexes."
			// Princess_LovesNPC: "{NPCName} really pushes me to do my best!"
		}
	}

	G1T1_Brock.DisplayName: Lider de gimnasio de tipo Roca
	G1T2_Misty.DisplayName: Lider de gimnasio de tipo Agua
	G1T3_LtSurge.DisplayName: Lider de gimnasio de tipo Eléctrico
	G1T4_Erika.DisplayName: Lider de gimnasio de tipo Planta
