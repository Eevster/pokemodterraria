		Tooltip:
			'''
			Cuando tu Pokemon golpea a un enemigo en un radio de {0} bloques:
			{1} extra de daño de Pokemon
			El entrenador obtiene el buff Miel
			'''
	}

	RedTrainerGlove: {
		DisplayName: Guante rojo de entrenador
		Tooltip:
			'''
			Cuando tu Pokemon golpea a un enemigo en un radio de {0} bloques:
			{1} extra de daño de Pokemon
			20% de probabilidad de inflingir el debuff ¡En llamas!
			'''
