	G1T6_Sabrina.DisplayName: Lider de gimnasio de tipo Psíquico
	G1T7_Blaine.DisplayName: Lider de gimnasio de tipo Fuego
	G1T8_Giovanni.DisplayName: Lider de gimnasio de tipo Tierra
}

Bestiary: {
	// PokemonScientist.BestiaryEntry: The brilliant mind at the frontier of Pokemon genetic research, the Pokemon Scientist can use Fossils and other Genetic Samples to Revitalise extinct species of Pokemon.
	// MoveTutor.BestiaryEntry: The Move Tutor is an experienced Pokemon enthusiast who knows all there is to know about moves. They can teach pokemon moves that they have forgotten.
}

Dialogue: {
	PokemonProfessor: {
		StandardDialogue1: ¡Hola! ¡Bienvenido al mundo de Pokémod! ¡Me llamo OAK! ¡Pero la gente me llama el Profesor Pokémon!
		StandardDialogue2: Para algunos, los Pokémon son mascotas. Pero otros los usan para pelear. En cuanto a mí... Estudio a los Pokémon como profesión.
		StandardDialogue3: ¡Puedo darte todo lo que necesitas para comenzar tu viaje!
	}

	FishermanTrainer: {
		StandardDialogue1: Hola, ¿te interesa la pesca?
		DefeatedDialogue: ¡Qué vergüenza! ¡Me han vencido en mi propio lugar de pesca!
	}

	PokemonScientist: {
		StandardDialogue1: Pareces alguien a quien le gusta cavar. ¡Solo puedo imaginar las maravillas que yacen bajo nuestros pies!
		StandardDialogue2: ¿Tienes algo interesante que mostrarme? ¿Quizás una roca? ¿Quizás una piedra antigua?
		StandardDialogue3: ¡Si me traes muestras genéticas puedo revivir Pokemon extintos!
		Button: Procesar muestras
		MissingSamples: " Se necesitan más muestras."
		MissingSamplesDialogue: Necesitaré más información genética para revitalizar un espécimen intacto.
		NoSamples: ¡No hay muestras en el inventario!
		NoSamplesDialogue: Si me traes muestras genéticas puedo hacer algo increíble con ellas. Quizás encuentres fósiles adecuados bajo tierra.
		NoBall: ¡No hay pokeballs en el inventario!
		NoBallDialogue: Necesitaré una Pokeball para albergar al espécimen revitalizado.
		LowLevel: Nivel de mundo demasiado bajo
		LowLevelDialogue: Esta muestra contiene una energía poderosa. Necesitaré investigar más antes de poder procesarla.
		Success: ¡Renacimiento exitoso!
		SuccessDialogue: ¡Hemos creado un ejemplar vivo de {0}! Cuídalo bien.
	}

	MoveTutor: {
		StandardDialogue1: Tus Pokemon parecen fuertes, pero siempre pueden volverse más fuertes.
		StandardDialogue2: ¡Un buen entrenador nunca deja de intentar mejorar sus habilidades!
		StandardDialogue3: ¡Puedo enseñar a tus Pokemon movimientos que han olvidado!
		Button: Aprender movimiento
	}

	G1T1_Brock: {
		StandardDialogue1: ¡Creo en la gran resistencia de la roca y en la determinación! ¿Todavía quieres desafiarme?
		DefeatedDialogue: Mi dura defensa no soportó los ataques de tu equipo Pokémon... Eres más fuerte de lo que pensaba...
	}

	G1T2_Misty: {
		StandardDialogue1: ¡Mi táctica es la ofensiva total con los Pokemon de tipo agua!
		DefeatedDialogue: ¡Uauuu! ¡Eres demasiado! ¡Muy bien! ¡Toma la Medalla Cascada para que todos sepan que me has ganado!
	}

	G1T3_LtSurge: {
		StandardDialogue1: ¡Oye! ¿Pero qué haces? ¡No resistirás mucho luchando! ¡Seguro!
		DefeatedDialogue: ¡Rayos, me has ganado! Te mereces la Medalla Trueno, sin lugar a dudas. ¡Ha sido un combate emocionante!
	}

	G1T4_Erika: {
		StandardDialogue1: Hola... bonito día, ¿verdad? Se está tan bien... Podría hasta dormirme... Me llamo Erika.
		DefeatedDialogue: ¿Estás catalogando Pokémon? Debo decir que estoy impresionada. Yo nunca recogería un Pokémon con poco atractivo.
	}

	G1T5_Koga: {
		StandardDialogue1: ¡Como maestro ninja, te enseñaré qué es el miedo! ¡Sentirás la desesperación de las técnicas del envenenamiento y del sueño!
		DefeatedDialogue: ¡Hmph! ¡Has demostrado tu valía!
	}

	G1T6_Sabrina: {
		StandardDialogue1: Aquí estás, tal y como predije. Tengo poderes psíquicos desde que era niña. No me gusta combatir, pero si así lo deseas... ¡Te demostraré de lo que soy capaz!
		DefeatedDialogue: Tu poder... Quizá no pueda predecir del todo lo que nos depara el futuro...
	}

	G1T7_Blaine: {
		StandardDialogue1: ¡Mis feroces Pokemon quemarán a todo aquel que me desafíe! ¡Ja! ¡Mejor que tengas un antiquemaduras!
		DefeatedDialogue: ¡Increíble! Mi poder se ha consumido por completo. Pero la llama de mi voluntad no solo no se ha apagado, ¡sino que se ha avivado todavía más!
	}

	G1T8_Giovanni: {
		StandardDialogue1: ¡No me contendré! ¡Te enfrentarás a Giovanni, el mejor Entrenador!
		DefeatedDialogue: ¡Ja! Fue una pelea realmente intensa. ¡Has ganado!
	}
}

