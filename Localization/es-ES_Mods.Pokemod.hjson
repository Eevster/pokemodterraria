		DisplayName: Super guante de entrenador
		Tooltip:
			'''
			Cuando tu Pokemon golpea a un enemigo en un radio de {0} bloques:
			{1} extra de daño de Pokemon
			'''
	}

	HyperTrainerGlove: {
		DisplayName: Ultra guante de entrenador
